# ================================
# Application
# ================================
APP_ENV=development
APP_NAME=mastery-engine
APP_PORT=8000
APP_LOG_LEVEL=INFO

# ================================
# Database
# ================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=mastery_engine
POSTGRES_USER=mastery
POSTGRES_PASSWORD=changeme_in_production
DATABASE_URL=postgresql+asyncpg://mastery:changeme_in_production@postgres:5432/mastery_engine
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ================================
# Redis
# ================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ================================
# Security
# ================================
JWT_SECRET_KEY=changeme_in_production_use_a_long_random_string
# Task 025-deploy: RS256 is the production default. Use HS256 only for local dev
# (no key files needed). Production requires JWT_KEYS_DIR + key pair.
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_ISSUER=https://api.masteryengine.com
JWT_AUDIENCE=mastery-engine-api
# Path to RSA keypair (private + public PEM files). Generate with:
#   openssl genrsa -out keys/jwt-private.pem 4096
#   openssl rsa -in keys/jwt-private.pem -pubout -out keys/jwt-public.pem
JWT_KEYS_DIR=

# ================================
# CORS
# ================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ================================
# Frontend
# ================================
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Mastery Engine
# Used by the backend to build absolute URLs in emails (e.g. beta invite links).
FRONTEND_BASE_URL=http://localhost:3000

# ================================
# SMTP / Email (Task 025-deploy)
# ================================
# Required in production for password resets, beta invites, etc.
# In dev/test, leave SMTP_USERNAME empty to use an in-memory client (no emails sent).
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=noreply@masteryengine.com
SMTP_FROM_NAME=Mastery Engine

# ================================
# Monitoring
# ================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
# Required — compose will refuse to start without this.
GRAFANA_PASSWORD=changeme_use_a_strong_password

# ================================
# Observability — Sentry (Task 027-verify)
# ================================
# Optional — leave empty to disable Sentry. When set, the backend initializes
# the Sentry SDK at startup with PII scrubbing.
SENTRY_DSN=

# ================================
# AI (optional — disabled by default for beta)
# ================================
AI_ENABLED=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ================================
# Nginx
# ================================
NGINX_PORT=80
NGINX_SSL_PORT=443

# ================================
# API URL (build arg for frontend Docker image)
# ================================
API_URL=https://app.masteryengine.com

# ================================
# Closed Beta
# ================================
CLOSED_BETA_ENABLED=false
MAX_BETA_USERS=20
BETA_INVITE_TOKEN_TTL_HOURS=168

# Beta Feature Flags
BETA_FLAG_LEARNING_ENABLED=true
BETA_FLAG_CONTENT_AUTHORING_ENABLED=true
BETA_FLAG_AI_ENABLED=false
BETA_FLAG_NOTIFICATIONS_ENABLED=true
BETA_FLAG_ANALYTICS_ENABLED=true
BETA_FLAG_ADMIN_CONSOLE_ENABLED=true
